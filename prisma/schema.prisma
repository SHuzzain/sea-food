generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

enum Status {
  ACTIVE
  INACTIVE
}

enum PaymentMode {
  CASH
  UPI
  BANK
  CHEQUE
}

enum LedgerType {
  OPENING
  SALE
  PAYMENT
  ADJUSTMENT
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  status       Status   @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id                 String        @id @default(cuid())
  name               String
  mobile             String?
  address            String?
  openingBalance     Decimal       @default(0) @db.Decimal(12, 2)
  outstandingBalance Decimal       @default(0) @db.Decimal(12, 2)
  status             Status        @default(ACTIVE)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  sales              Sale[]
  payments           Payment[]
  ledgerEntries      LedgerEntry[]

  @@index([name])
  @@index([mobile])
  @@index([status])
}

model Supplier {
  id        String     @id @default(cuid())
  name      String
  mobile    String?
  address   String?
  status    Status     @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  purchases Purchase[]

  @@index([name])
  @@index([mobile])
  @@index([status])
}

model Product {
  id            String         @id @default(cuid())
  name          String
  unit          String         @default("kg")
  status        Status         @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]

  @@index([name])
  @@index([status])
}

model Purchase {
  id           String         @id @default(cuid())
  purchaseDate DateTime
  supplierId   String
  totalAmount  Decimal        @db.Decimal(12, 2)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  supplier     Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items        PurchaseItem[]

  @@index([purchaseDate])
  @@index([supplierId])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  productId  String
  kg         Decimal  @db.Decimal(12, 3)
  rate       Decimal  @db.Decimal(12, 2)
  amount     Decimal  @db.Decimal(12, 2)
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([productId])
}

model Sale {
  id              String        @id @default(cuid())
  invoiceNo       String        @unique
  invoiceDate     DateTime
  customerId      String
  previousBalance Decimal       @db.Decimal(12, 2)
  totalAmount     Decimal       @db.Decimal(12, 2)
  receivedAmount  Decimal       @default(0) @db.Decimal(12, 2)
  currentBalance  Decimal       @db.Decimal(12, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items           SaleItem[]
  ledgerEntries   LedgerEntry[]

  @@index([invoiceDate])
  @@index([customerId])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String
  kg        Decimal @db.Decimal(12, 3)
  rate      Decimal @db.Decimal(12, 2)
  amount    Decimal @db.Decimal(12, 2)
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([productId])
}

model Payment {
  id            String        @id @default(cuid())
  customerId    String
  paymentDate   DateTime
  amount        Decimal       @db.Decimal(12, 2)
  paymentMode   PaymentMode
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  ledgerEntries LedgerEntry[]

  @@index([paymentDate])
  @@index([customerId])
}

model LedgerEntry {
  id          String     @id @default(cuid())
  customerId  String
  entryDate   DateTime
  type        LedgerType
  refNo       String?
  description String?
  debit       Decimal    @default(0) @db.Decimal(12, 2)
  credit      Decimal    @default(0) @db.Decimal(12, 2)
  balance     Decimal    @db.Decimal(12, 2)
  saleId      String?
  paymentId   String?
  createdAt   DateTime   @default(now())
  customer    Customer   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  sale        Sale?      @relation(fields: [saleId], references: [id], onDelete: SetNull)
  payment     Payment?   @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([entryDate])
  @@index([customerId])
  @@index([type])
}

model Expense {
  id          String   @id @default(cuid())
  expenseDate DateTime
  category    String
  amount      Decimal  @db.Decimal(12, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([expenseDate])
}

model AppSettings {
  id              String   @id @default("default")
  businessName    String   @default("ARF Seafoods")
  businessTagline String   @default("Fresh from nature, delivered with care")
  businessAddress String   @default("")
  businessMobile  String   @default("")
  updatedAt       DateTime @updatedAt
}
